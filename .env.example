# ── Anthropic API ───────────────────────────────────────────────────
# Get your key from: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-your-key-here

# ── Model selection ──────────────────────────────────────────────────
# Used for file analysis at /upload (quality matters here)
# Options: claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-opus-4-7

# Used for chat at /chat (speed matters here)
# Options: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-7
CLAUDE_CHAT_MODEL=claude-haiku-4-5-20251001

# ── Server ───────────────────────────────────────────────────────────
PORT=8000

# ── Cloudinary (file storage — survives server restarts) ─────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Session storage ──────────────────────────────────────────────────
# Only "memory" is supported — sessions are lost on server restart
SESSION_STORE=memory
SESSION_TTL=3600           # seconds of inactivity before a session expires
SESSION_MAX_MESSAGES=10    # rolling message window per session
SESSION_MAX_COUNT=200      # max concurrent sessions in memory

# ── RAG: database — pick ONE option, leave the other blank ───────────
#
# Option A: direct PostgreSQL connection string
#   Works with Neon (free), Render, Railway, AWS RDS, Aurora, and any Postgres host.
#   Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
#   Neon:   postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
#   Render: postgresql://user:pass@dpg-xxx.oregon-postgres.render.com/dbname
#   RDS:    postgresql://user:pass@your-instance.rds.amazonaws.com:5432/dbname
DATABASE_URL=

# Option B: Supabase REST client
#   supabase.com → your project → Settings → API
#   Use the service_role (secret) key — never the anon key on a server
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...your-service-role-key

# ── RAG: embeddings — pick ONE option, leave the other blank ─────────
#
# Option A: Hugging Face Inference API (recommended for cloud, free account)
#   huggingface.co → Settings → Access Tokens → New token (read)
HUGGINGFACE_API_KEY=

# Option B: local sentence-transformers — used automatically when HF key is blank
#   No key needed. Model (~90 MB) downloads on first run and is cached.
#   Leave blank to use the default (all-MiniLM-L6-v2), or set a custom model name:
SENTENCE_TRANSFORMER_MODEL=
