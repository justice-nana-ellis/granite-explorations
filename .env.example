# ── Anthropic API ───────────────────────────────────────────────────
# Get your key from: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-your-key-here

# ── Model selection ──────────────────────────────────────────────────
# Used for file analysis at /upload (quality matters here)
# Options: claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-opus-4-7

# Used for chat at /chat (speed matters here)
# Options: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-7
CLAUDE_CHAT_MODEL=claude-haiku-4-5-20251001

# ── Server ───────────────────────────────────────────────────────────
PORT=8000

# ── Session storage ──────────────────────────────────────────────────
# Only "memory" is supported — sessions are lost on server restart
SESSION_STORE=memory
SESSION_TTL=3600           # seconds of inactivity before a session expires
SESSION_MAX_MESSAGES=10    # rolling message window per session
SESSION_MAX_COUNT=200      # max concurrent sessions in memory
